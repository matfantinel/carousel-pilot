{
	"name": "carousel-pilot",
	"version": "0.0.4",
	"description": "Enhance any CSS scroll snap carousel with prev/next navigation, autoplay, and infinite looping — no framework required.",
	"author": "Matheus Fantinel <matt@fantinel.dev> (https://fantinel.dev)",
	"homepage": "https://github.com/matfantinel/carousel-pilot",
	"license": "MIT",
	"keywords": [
		"slider",
		"carousel",
		"scroll snap"
	],
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && npm run prepack",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && vite build --config vite.lib.config.js && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build"
	},
	"files": [
		"dist",
		"!dist/examples",
		"!dist/markdown",
		"!dist/landing-page",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css",
		"./dist/carousel-pilot.js"
	],
	"main": "./dist/carousel-pilot.js",
	"module": "./dist/carousel-pilot.js",
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"import": "./dist/carousel-pilot.js"
		}
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@fontsource/maple-mono": "^5.2.6",
		"@humanspeak/svelte-markdown": "^1.5.2",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@storybook/sveltekit": "^10.4.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^22",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-storybook": "^10.4.0",
		"eslint-plugin-svelte": "^3.17.0",
		"github-slugger": "^2.0.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prism-svelte": "^0.5.0",
		"prismjs": "^1.30.0",
		"publint": "^0.3.18",
		"storybook": "^10.4.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	}
}
